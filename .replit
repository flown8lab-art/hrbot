modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bot/main.py"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["openssl", "nano"]

[userenv]

[userenv.shared]
ADMIN_ID = "7166513643"

[deployment]
deploymentTarget = "vm"
run = ["python", "bot/main.py"]
publicDir = "dist/public"
